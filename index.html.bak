<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sidereal Software - Engineering the night sky</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      @keyframes pulse-slow {
        0%,
        100% {
          opacity: 0.2;
        }
        50% {
          opacity: 0.7;
        }
      }
      .star {
        position: absolute;
        background: white;
        border-radius: 50%;
        animation: pulse-slow var(--duration) infinite;
      }
    </style>
  </head>
  <body
    class="bg-gradient-to-b from-[#0a0e27] via-[#0f1433] to-[#1a1f4d] text-white min-h-screen">
    <!-- Starfield Background -->
    <div id="starfield" class="fixed inset-0 pointer-events-none overflow-hidden"></div>

    <!-- Header -->
    <header
      class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-[#0a0e27]/80 backdrop-blur-md">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href="#home" class="flex items-center space-x-3 group">
            <img src="./logo.png" alt="Chameleon Logo" class="h-10 w-10 invert" />
            <div class="flex flex-col">
              <span class="font-semibold tracking-tight">Sidereal Software</span>
            </div>
          </a>
          <div class="hidden md:flex items-center space-x-1">
            <a
              href="#home"
              class="px-4 py-2 rounded-md text-white/70 hover:text-white hover:bg-white/5 transition-colors"
              >Home</a
            >
            <a
              href="#services"
              class="px-4 py-2 rounded-md text-white/70 hover:text-white hover:bg-white/5 transition-colors"
              >Services</a
            >
            <a
              href="#contact"
              class="px-4 py-2 rounded-md text-white/70 hover:text-white hover:bg-white/5 transition-colors"
              >Contact</a
            >
          </div>
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 rounded-md hover:bg-white/10 transition-colors">
            <svg
              id="menu-icon"
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg
              id="close-icon"
              class="w-6 h-6 hidden"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div id="mobile-menu" class="hidden md:hidden py-4 border-t border-white/10">
          <a
            href="#home"
            class="block px-4 py-3 rounded-md text-white/70 hover:text-white hover:bg-white/5 transition-colors mobile-menu-link"
            >Home</a
          >
          <a
            href="#services"
            class="block px-4 py-3 rounded-md text-white/70 hover:text-white hover:bg-white/5 transition-colors mobile-menu-link"
            >Services</a
          >
          <a
            href="#contact"
            class="block px-4 py-3 rounded-md text-white/70 hover:text-white hover:bg-white/5 transition-colors mobile-menu-link"
            >Contact</a
          >
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="relative z-10">
      <section
        id="home"
        class="relative h-screen flex items-center justify-center overflow-hidden">
        <div
          class="absolute inset-0 bg-gradient-to-b from-blue-600/20 via-purple-600/10 to-transparent"></div>
        <div
          class="absolute inset-0 bg-gradient-to-tr from-blue-500/10 via-transparent to-purple-500/10"></div>
        <div
          class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-600/5 via-transparent to-transparent"></div>

        <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <div class="space-y-8">
            <div class="space-y-6">
              <h1
                class="text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold tracking-tight">
                Engineering the
                <span
                  class="bg-gradient-to-r from-blue-400 via-purple-400 to-blue-500 bg-clip-text text-transparent">
                  night sky
                </span>
              </h1>
              <p
                class="text-xl md:text-2xl text-white/70 leading-relaxed max-w-3xl mx-auto">
                Production-quality astronomy software solutions for observatories,
                research teams, and scientific institutions.
              </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="#services"
                class="group inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-blue-500 to-purple-600 rounded-md hover:from-blue-600 hover:to-purple-700 transition-all text-lg">
                Explore Services
                <svg
                  class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
              <a
                href="#contact"
                class="inline-flex items-center justify-center px-8 py-4 border border-white/20 rounded-md hover:bg-white/10 transition-all text-lg">
                Get in Touch
              </a>
            </div>

            <div class="grid grid-cols-3 gap-6 pt-12 max-w-2xl mx-auto">
              <div>
                <div
                  class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent">
                  10+
                </div>
                <div class="text-sm md:text-base text-white/60 mt-2">
                  Years in Astronomy
                </div>
              </div>
              <div>
                <div
                  class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent">
                  ~10
                </div>
                <div class="text-sm md:text-base text-white/60 mt-2">
                  Years Observatory Software
                </div>
              </div>
              <div>
                <div
                  class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent">
                  100%
                </div>
                <div class="text-sm md:text-base text-white/60 mt-2">
                  Production Quality
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Scroll indicator -->
        <a
          href="#services"
          class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce cursor-pointer">
          <svg
            class="w-8 h-8 text-white/40"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </section>

      <!-- Services Section -->
      <section id="services" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Services</h2>
          <p class="text-white/70 max-w-2xl mx-auto">
            Full-stack astronomy software development with deep domain expertise
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
          <!-- Service Cards -->
          <div
            class="p-6 rounded-lg border border-white/10 bg-white/5 backdrop-blur-sm hover:bg-white/10 transition-all">
            <svg
              class="w-12 h-12 text-blue-400 mb-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <h3 class="text-xl font-semibold mb-2">Observatory Applications</h3>
            <p class="text-white/70 text-sm">
              Control software, automation systems, and telescope integrations designed
              for real-world observatory operations.
            </p>
          </div>

          <div
            class="p-6 rounded-lg border border-white/10 bg-white/5 backdrop-blur-sm hover:bg-white/10 transition-all">
            <svg
              class="w-12 h-12 text-blue-400 mb-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="text-xl font-semibold mb-2">Scientific Web Platforms</h3>
            <p class="text-white/70 text-sm">
              Django-based web applications, TOM Toolkit deployments, and data portals
              for astronomical research teams.
            </p>
          </div>

          <div
            class="p-6 rounded-lg border border-white/10 bg-white/5 backdrop-blur-sm hover:bg-white/10 transition-all">
            <svg
              class="w-12 h-12 text-blue-400 mb-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
            <h3 class="text-xl font-semibold mb-2">Python Libraries & APIs</h3>
            <p class="text-white/70 text-sm">
              Reusable libraries, RESTful APIs, and data pipelines built with Python
              best practices and scientific rigor.
            </p>
          </div>

          <div
            class="p-6 rounded-lg border border-white/10 bg-white/5 backdrop-blur-sm hover:bg-white/10 transition-all">
            <svg
              class="w-12 h-12 text-blue-400 mb-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
            </svg>
            <h3 class="text-xl font-semibold mb-2">Backend Systems</h3>
            <p class="text-white/70 text-sm">
              Scalable database architectures, data processing pipelines, and
              integration with existing observatory infrastructure.
            </p>
          </div>

          <div
            class="p-6 rounded-lg border border-white/10 bg-white/5 backdrop-blur-sm hover:bg-white/10 transition-all">
            <svg
              class="w-12 h-12 text-blue-400 mb-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
            </svg>
            <h3 class="text-xl font-semibold mb-2">Drivers & Integrations</h3>
            <p class="text-white/70 text-sm">
              Hardware drivers, instrument control software, and integrations with INDI,
              and proprietary systems.
            </p>
          </div>

          <div
            class="p-6 rounded-lg border border-white/10 bg-white/5 backdrop-blur-sm hover:bg-white/10 transition-all">
            <svg
              class="w-12 h-12 text-blue-400 mb-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <h3 class="text-xl font-semibold mb-2">Frontend Development</h3>
            <p class="text-white/70 text-sm">
              Modern React interfaces with TypeScript, real-time data visualization, and
              responsive design for astronomers.
            </p>
          </div>
        </div>

        <!-- Technology Stack -->
        <div
          class="rounded-lg border border-white/10 bg-white/5 backdrop-blur-sm p-8 md:p-12">
          <h3 class="text-2xl font-bold mb-8 text-center">Technology Stack</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <div>
              <h4 class="mb-4 text-blue-300 font-semibold">Backend</h4>
              <ul class="space-y-2 text-white/70 text-sm">
                <li>Python 3.9+</li>
                <li>Django & Django REST</li>
                <li>FastAPI</li>
                <li>Celery</li>
                <li>PostgreSQL</li>
                <li>Redis</li>
              </ul>
            </div>
            <div>
              <h4 class="mb-4 text-purple-300 font-semibold">Frontend</h4>
              <ul class="space-y-2 text-white/70 text-sm">
                <li>React</li>
                <li>TypeScript</li>
                <li>JavaScript</li>
                <li>WebSocket</li>
              </ul>
            </div>
            <div>
              <h4 class="mb-4 text-blue-300 font-semibold">Astronomy</h4>
              <ul class="space-y-2 text-white/70 text-sm">
                <li>TOM Toolkit</li>
                <li>Astropy</li>
                <li>INDI</li>
              </ul>
            </div>
            <div>
              <h4 class="mb-4 text-purple-300 font-semibold">DevOps</h4>
              <ul class="space-y-2 text-white/70 text-sm">
                <li>Docker</li>
                <li>GitHub Actions</li>
                <li>pytest</li>
                <li>Git</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- Contact Section -->
      <section id="contact" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Get in Touch</h2>
          <p class="text-xl text-white/70 max-w-3xl mx-auto">
            Let's discuss your astronomy software project and explore how we can work
            together
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <!-- Contact Info -->
          <div class="space-y-8">
            <div
              class="rounded-lg border border-white/10 bg-white/5 backdrop-blur-sm p-8">
              <div class="flex items-center space-x-3 mb-6">
                <svg
                  class="w-6 h-6 text-blue-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <h3 class="text-2xl font-bold">Contact Information</h3>
              </div>
              <div class="space-y-4 text-white/70">
                <p>
                  For project inquiries, questions, or just to say hello, please use the
                  contact form or reach out directly via email.
                </p>
                <div class="pt-4 border-t border-white/10">
                  <p class="text-sm text-white/50 mb-2">Email</p>
                  <p class="text-white/90">contact@siderealsoftware.dev</p>
                </div>
                <div class="pt-4 border-t border-white/10">
                  <p class="text-sm text-white/50 mb-2">Response Time</p>
                  <p class="text-white/90">Typically within 1-2 business days</p>
                </div>
              </div>
            </div>

            <div
              class="rounded-lg border border-blue-400/30 bg-gradient-to-br from-blue-500/10 to-purple-600/10 backdrop-blur-sm p-8">
              <h3 class="text-xl font-bold mb-4">Experience</h3>
              <div class="space-y-4">
                <div class="flex items-start space-x-3">
                  <div class="w-2 h-2 rounded-full bg-blue-400 mt-2"></div>
                  <div>
                    <div class="font-semibold text-white/90">Steward Observatory</div>
                    <div class="text-sm text-white/60">University of Arizona</div>
                  </div>
                </div>
                <div class="flex items-start space-x-3">
                  <div class="w-2 h-2 rounded-full bg-purple-400 mt-2"></div>
                  <div>
                    <div class="font-semibold text-white/90">Caltech</div>
                    <div class="text-sm text-white/60">
                      California Institute of Technology
                    </div>
                  </div>
                </div>
                <div class="flex items-start space-x-3">
                  <div class="w-2 h-2 rounded-full bg-blue-400 mt-2"></div>
                  <div>
                    <div class="font-semibold text-white/90">AURA/NOIRLab</div>
                    <div class="text-sm text-white/60">
                      Association of Universities for Research in Astronomy
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer
      class="relative z-10 border-t border-white/10 bg-[#0a0e27]/80 backdrop-blur-md mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="text-center text-white/50 text-sm">
          <p>&copy; <span id="year"></span> Sidereal Software. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      // Generate starfield
      const starfield = document.getElementById("starfield");
      for (let i = 0; i < 150; i++) {
        const star = document.createElement("div");
        star.className = "star";
        star.style.top = `${Math.random() * 100}%`;
        star.style.left = `${Math.random() * 100}%`;
        star.style.width = `${Math.random() * 2 + 0.5}px`;
        star.style.height = star.style.width;
        star.style.setProperty("--duration", `${Math.random() * 3 + 2}s`);
        star.style.opacity = Math.random() * 0.5 + 0.2;
        starfield.appendChild(star);
      }

      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById("mobile-menu-btn");
      const mobileMenu = document.getElementById("mobile-menu");
      const menuIcon = document.getElementById("menu-icon");
      const closeIcon = document.getElementById("close-icon");

      mobileMenuBtn.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
        menuIcon.classList.toggle("hidden");
        closeIcon.classList.toggle("hidden");
      });

      // Close mobile menu when clicking a link
      document.querySelectorAll(".mobile-menu-link").forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu.classList.add("hidden");
          menuIcon.classList.remove("hidden");
          closeIcon.classList.add("hidden");
        });
      });

      // Set current year
      document.getElementById("year").textContent = new Date().getFullYear();
    </script>
  </body>
</html>
